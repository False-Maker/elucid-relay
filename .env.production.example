POSTGRES_DB=elucid_relay
POSTGRES_USER=relay
POSTGRES_PASSWORD=change-me-postgres-password

GATEWAY_API_PORT=18080
PORTAL_PORT=18081

VAULT_KEY=replace-with-a-long-random-value-at-least-32-bytes
COOKIE_SECURE=true
CORS_ALLOWED_ORIGINS=https://relay.example.com
TRUSTED_PROXY_CIDRS=127.0.0.1,10.0.0.0/8
PORTAL_BASE_URL=https://relay.example.com
PUBLIC_BASE_URL=https://relay.example.com
PUBLIC_GATEWAY_API_URL=https://relay.example.com
VITE_API_BASE_URL=https://relay.example.com
VITE_RELAY_API_BASE_URL=/relay
RELAY_PROXY_URL=https://relay.example.com
MIGRATE_ON_START=false

OAUTH_WRAPPER_BEARER_TOKEN=replace-with-random-oauth-wrapper-token

SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM=Elucid Relay <noreply@example.com>
SMTP_TLS_MODE=starttls

STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_API_BASE_URL=https://api.stripe.com
BILLING_SUCCESS_URL=https://relay.example.com/?billing=success
BILLING_CANCEL_URL=https://relay.example.com/?billing=cancel

BACKUP_DIR=./backups/postgres
BACKUP_RETENTION_DAYS=14
